# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_PROJECT_ID: The Project ID of your Firebase Console project.
FIREBASE_PROJECT_ID=MY_FIREBASE_PROJECT_ID

# FIREBASE_APPLICATION_ID: The Mobile App ID from your Firebase Project Settings.
FIREBASE_APPLICATION_ID=MY_FIREBASE_APP_ID

# FIREBASE_API_KEY: The Web API Key from your Firebase Project Settings.
FIREBASE_API_KEY=MY_FIREBASE_API_KEY
